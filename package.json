{
  "name": "pdv-inteligente-web",
  "private": true,
  "version": "2.3.3",
  "type": "module",
  "main": "electron/main.js",
  "description": "Aurya ERP — frontend desktop (Electron) e web (Vite/React)",
  "author": "Aurya",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false NODE_ENV=production npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.32.0",
    "@google/generative-ai": "^0.24.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "axios": "^1.6.8",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.3",
    "react-router-dom": "^6.22.3",
    "react-toastify": "^11.0.5",
    "recharts": "^3.8.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.aurya.erp",
    "productName": "Aurya ERP",
    "copyright": "Copyright © Aurya",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "electron/assets/window-icon.jpeg",
      "signAndEditExecutable": false,
      "signDlls": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "pt_BR",
        "en_US"
      ],
      "language": "1046"
    }
  }
}
